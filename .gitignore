# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Local one-off dev/ops scripts that contain hardcoded credentials — never commit
/dev-server.log
/apply-grants.mjs
/apply-rls-fix.mjs
/fix-trigger-and-admin.mjs
/run-migrations.mjs
/seed-drivers.mjs
/setup-admin.mjs

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
